{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Jwt": {
    "Key": "development-secret-key-for-testing-only-256-bits",
    "Issuer": "ApiGateway",
    "Audience": "ApiGatewayUsers"
  },
  "Sso": {
    // Development SSO provider URL — point to a local or staging identity server
    "ProviderUrl": "https://dev-sso.example.com",
    // Development client ID registered with the dev/staging SSO provider
    "ClientId": "dev-sso-client-id",
    // IMPORTANT: Do NOT commit real secrets.
    // Use dotnet user-secrets for local development:
    //   dotnet user-secrets set "Sso:ClientSecret" "<your-dev-secret>"
    // Or set the environment variable:  SSO__ClientSecret
    "ClientSecret": ""
  }
}
