{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-secret-key-here-must-be-at-least-256-bits",
    "Issuer": "ApiGateway",
    "Audience": "ApiGatewayUsers"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Sso": {
    // SSO provider base URL — override per environment or via environment variable SSO__ProviderUrl
    "ProviderUrl": "https://sso.example.com",
    // OAuth 2.0 / OIDC client identifier registered with the SSO provider
    // Override via environment variable SSO__ClientId or user-secrets in development
    "ClientId": "your-sso-client-id",
    // IMPORTANT: Do NOT store the real client secret here.
    // Set the actual value using:
    //   - Environment variable:  SSO__ClientSecret
    //   - dotnet user-secrets (development only)
    //   - A secrets manager (e.g. Azure Key Vault, AWS Secrets Manager) in production
    "ClientSecret": ""
  }
}
